{
  "workflowApiVersion": "1.1",
  "type": "REST",

  "metaData": {
    "icon": "https://jcrow-cloud.github.io/mulepbox/v25/images/icon.png",
    "category": "custom",
    "configOnDrop": true
  },

  "lang": {
    "en-US": {
      "name": "Paubox Email",
      "description": "Send email via MuleSoft Paubox integration"
    }
  },

  "arguments": {
    "execute": {
      "url": "https://qeag-qa.questdiagnostics.com/qdx-preferences-xapi-v2/paubox/template-email",

      "inArguments": [
        {
          "data": {
            "template_name": "quest_appt_reminder_v1",
            "template_values": {
              "subscriberKey": "{{Contact.Key}}"
            },
            "message": {
              "recipients": [
                "{{Contact.Email}}"
              ],
              "headers": {
                "subject": "v 25 test",
                "from": "noreply@pcomm.questdiagnostics.com"
              },
              "allowNonTLS": false,
              "forceSecureNotification": false
            }
          }
        }
      ],

      "outArguments": [
        {
          "status": "{{response.status}}"
        }
      ],

      "securityOptions": {
        "securityType": "securityContext",
        "securityContextKey": "20260320custom_activity_pboxv20"
      }
    }
  },

  "configurationArguments": {
    "applicationExtensionKey": "PCOMM_paubox_v25",

    "save": {
      "url": "https://qeag-qa.questdiagnostics.com/qdx-preferences-xapi-v2/paubox/activity",
      "securityOptions": {
        "securityType": "securityContext",
        "securityContextKey": "20260320custom_activity_pboxv20"
      }
    },

    "validate": {
      "url": "https://qeag-qa.questdiagnostics.com/qdx-preferences-xapi-v2/paubox/activity",
      "securityOptions": {
        "securityType": "securityContext",
        "securityContextKey": "20260320custom_activity_pboxv20"
      }
    },

    "publish": {
      "url": "https://qeag-qa.questdiagnostics.com/qdx-preferences-xapi-v2/paubox/activity",
      "securityOptions": {
        "securityType": "securityContext",
        "securityContextKey": "20260320custom_activity_pboxv20"
      }
    },

    "stop": {
      "url": "https://qeag-qa.questdiagnostics.com/qdx-preferences-xapi-v2/paubox/activity",
      "securityOptions": {
        "securityType": "securityContext",
        "securityContextKey": "20260320custom_activity_pboxv20"
      }
    }
  },

  "schema": {
    "arguments": {
      "execute": {
        "inArguments": [
          {
            "data": {
              "dataType": "Object",
              "isNullable": true
            }
          }
        ],
        "outArguments": [
          {
            "status": {
              "dataType": "Text",
              "isNullable": true,
              "access": "visible"
            }
          }
        ]
      }
    }
  },

  "userInterfaces": {
    "configModal": {
      "url": "https://jcrow-cloud.github.io/mulepbox/v25/index.html",
      "height": 400,
      "width": 500,
      "fullscreen": false
    }
  }
}
